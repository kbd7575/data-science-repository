        "def pos_counts(tokens):\n",
        "    doc = nlp(\" \".join(tokens))\n",
        "    num_adj = sum(1 for t in doc if t.pos_ == \"ADJ\")\n",
        "    num_noun = sum(1 for t in doc if t.pos_ == \"NOUN\")\n",
        "    num_verb = sum(1 for t in doc if t.pos_ == \"VERB\")\n",
        "    num_adv = sum(1 for t in doc if t.pos_ == \"ADV\")\n",
        "    return {\n",
        "        \"num_adj\": num_adj,\n",
        "        \"num_noun\": num_noun,\n",
        "        \"num_verb\": num_verb,\n",
        "        \"num_adv\": num_adv\n",
        "    }\n",
        "\n",
        "def bow_pos_features(tokens, vocab):\n",
        "    #another BOW\n",
        "    features = bow_features(tokens, vocab)\n",
        "\n",
        "    #add POS counts\n",
        "    pos_feats = pos_counts(tokens)\n",
        "    features.update(pos_feats)\n",
        "\n",
        "    return features\n",
        "\n",
        "#BOW\n",
        "featuresets_pos = [\n",
        "    (bow_pos_features(tokens, vocab), label)\n",
        "    for tokens, label in cleaned_data_stop\n",
        "]\n",
        "\n",
        "#shuffle and split\n",
        "features4 = list(featuresets_pos)\n",
        "random.shuffle(features4)\n",
        "split_index4 = int(0.8 * len(features4))\n",
        "train_set4 = features4[:split_index4]\n",
        "test_set4  = features4[split_index4:]\n",
        "\n",
        "#train\n",
        "classifier4 = NaiveBayesClassifier.train(train_set4)\n",
        "\n",
        "#evaluate\n",
        "true4 = [label for (_, label) in test_set4]\n",
        "pred4 = [classifier4.classify(fs) for (fs, _) in test_set4]\n",
        "\n",
        "print(\"Experiment 4: BOW + POS Count Features\")\n",
        "print(classification_report(true4, pred4, digits=3))"
      ]

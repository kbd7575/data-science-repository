        "#wrote function to process tokens in one go. does not remove stop words\n",
        "def spacy_clean_tokens(tokens):\n",
        "    cleaned = []\n",
        "    for token in nlp(\" \".join(tokens)):\n",
        "        if token.text in string.punctuation: #remove punct\n",
        "            continue\n",
        "        if token.like_num: #remove numbers\n",
        "            continue\n",
        "        if not token.is_alpha:\n",
        "            continue\n",
        "        cleaned.append(token.lemma_) #lemmanize\n",
        "    return cleaned"
      ]

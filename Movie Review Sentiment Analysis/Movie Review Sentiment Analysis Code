      "source": [
        "def bow_features(tokens, vocab):\n",
        "    features = {} #creates dictionary\n",
        "    token_set = set(tokens)\n",
        "\n",
        "    for word in vocab:\n",
        "        features[f\"contains({word})\"] = (word in token_set)\n",
        "\n",
        "    return features"
      ]

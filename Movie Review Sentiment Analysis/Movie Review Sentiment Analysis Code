        "#made a group of that are typically associated with positive sentiment\n",
        "positive_words = {\n",
        "    \"good\",\"great\",\"amazing\",\"wonderful\",\"enjoy\",\"love\",\"excellent\",\"positive\",\n",
        "    \"thrilling\",\"delight\",\"charming\",\"fun\",\"joy\"\n",
        "}\n",
        "\n",
        "#made a group of that are typically associated with negative sentiment\n",
        "negative_words = {\n",
        "    \"bad\",\"terrible\",\"awful\",\"boring\",\"hate\",\"poor\",\"negative\",\"dull\",\"worse\",\n",
        "    \"mess\",\"annoy\",\"sad\",\"problem\"\n",
        "}\n",
        "\n",
        "def sentiment_counts(tokens):\n",
        "    token_set = set(tokens)\n",
        "    pos_count = sum(1 for w in token_set if w in positive_words)\n",
        "    neg_count = sum(1 for w in token_set if w in negative_words)\n",
        "    return {\n",
        "        \"pos_lex_count\": pos_count,\n",
        "        \"neg_lex_count\": neg_count\n",
        "    }\n",
        "\n",
        "def bow_lex_features(tokens, vocab):\n",
        "    features = bow_features(tokens, vocab)\n",
        "    lex_feats = sentiment_counts(tokens)\n",
        "    features.update(lex_feats)\n",
        "    return features\n",
        "\n",
        "#BOW of EXP 4\n",
        "featuresets_lex = [\n",
